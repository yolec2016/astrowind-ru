---
const {
  title = 'Blog',
  subtitle = '',
} = Astro.props;
---

<header class="mb-10 md:mb-16 text-center max-w-3xl mx-auto">

  <!-- H1 -->
  <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tight font-heading text-slate-900 dark:text-white">
    {title}
  </h1>

  <!-- Subtitle -->
  {subtitle && (
    <p class="mt-3 md:mt-4 text-lg md:text-xl text-gray-500 dark:text-slate-400 font-medium leading-relaxed">
      {subtitle}
    </p>
  )}

</header>