---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'OEM/ODM завод кухонной техники в Китае | Производитель и поставщик оптом',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="OEM / ODM завод кухонной техники в Китае"
    title="Производитель мелкой кухонной техники OEM / ODM для B2B рынка"
    subtitle="Мы — китайский OEM/ODM завод и поставщик кухонной техники оптом: электрические чайники, рисоварки, мультиварки и другая мелкая бытовая техника. Работаем с импортёрами, дистрибьюторами и брендами private label по всему миру."
    actions={[{ variant: 'primary', target: '_blank', text: 'Получить OEM / ODM коммерческое предложение', href: 'https://www.yolec-electronics.com/contact/', target: '_blank', }]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c',
      alt: 'OEM ODM завод кухонной техники Китай производство',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="OEM / ODM производственные возможности завода"
    subtitle="Полный цикл производства кухонной техники под СТМ (private label) напрямую с фабрики в Китае"
    columns={3}
    items={[
      {
        title: 'OEM производство (оптом)',
        description:
          'Готовые модели с вашим логотипом и упаковкой. Оптовые поставки напрямую с завода в Китае.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'ODM разработка',
        description:
          'Разработка новых моделей кухонной техники под ваш рынок: дизайн, функции и технические улучшения.',
        icon: 'tabler:tools',
      },
      {
        title: 'Private Label (СТМ)',
        description:
          'Полный запуск бренда под ключ: OEM/ODM производство + упаковка + брендирование.',
        icon: 'tabler:package',
      },
      {
        title: 'Контроль качества (QC)',
        description:
          'Многоуровневый контроль качества на каждом этапе производства кухонной техники.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Экспорт в 30+ стран',
        description:
          'Поставки в Европу, Ближний Восток, Южную Америку и другие B2B рынки.',
        icon: 'tabler:world',
      },
      {
        title: 'Быстрые образцы',
        description:
          'Оперативная разработка и отправка образцов для OEM/ODM проектов.',
        icon: 'tabler:clock',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Собственный OEM/ODM завод в Китае',
        description:
          'Полный производственный цикл: штамповка металла, литьё пластика, сборка и тестирование кухонной техники.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Стабильное производство оптом',
        description:
          '3 производственные линии и около 200 сотрудников обеспечивают стабильные поставки для B2B клиентов.',
        icon: 'tabler:stack',
      },
      {
        title: 'Гибкие OEM / ODM решения',
        description:
          'Поддержка малых и крупных оптовых заказов для импортеров, дистрибьюторов и брендов.',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Инженерная поддержка',
        description:
          'Помощь в разработке продукта и технической оптимизации под рынок клиента.',
        icon: 'tabler:cpu',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1525909002-1b05e0c869d8',
      alt: 'OEM ODM factory kitchen appliances China production line',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Почему выбирают наш OEM / ODM завод в Китае
      </h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Снижение себестоимости',
        description:
          'Прямые заводские цены без посредников для оптовых покупателей и импортеров.',
        icon: 'tabler:coin',
      },
      {
        title: 'Быстрый запуск продукта',
        description:
          'Помогаем быстро запустить OEM/ODM проект кухонной техники под ваш бренд.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Поддержка private label брендов',
        description:
          'Полное брендирование: логотип, упаковка и дизайн под ваш рынок.',
        icon: 'tabler:brush',
      },
      {
        title: 'Готовность к международным рынкам',
        description:
          'Продукция соответствует стандартам CE / RoHS / LFGB для экспорта.',
        icon: 'tabler:checklist',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664688-cf412ec27db2',
      alt: 'OEM ODM advantages kitchen appliances factory China',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Преимущества OEM / ODM сотрудничества с фабрикой
      </h3>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Отзывы B2B клиентов о нашем OEM / ODM заводе"
    testimonials={[
      {
        testimonial:
          'Стабильное качество и быстрая коммуникация. Успешно запустили линейку электрических чайников под private label.',
        name: 'Импортер из Германии',
        job: 'Оптовые закупки кухонной техники',
      },
      {
        testimonial:
          'Фабрика помогла нам разработать новый ODM продукт и выйти на рынок быстрее конкурентов.',
        name: 'Дистрибьютор из ОАЭ',
        job: 'B2B поставки',
      },
      {
        testimonial:
          'Хороший OEM завод с стабильным производством больших объемов кухонной техники.',
        name: 'Бренд из Польши',
        job: 'Private Label',
      },
    ]}
    callToAction={{
      target: '_blank',
      text: 'Получить больше кейсов OEM/ODM',
      href: 'https://www.yolec-electronics.com/about/',
      target: '_blank',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Запросить OEM / ODM цену от завода',
        href: 'https://www.yolec-electronics.com/contact/',
        target: '_blank',
      },
    ]}
    title="Запустите производство кухонной техники под вашим брендом"
    subtitle="Получите прямое коммерческое предложение от OEM/ODM завода в Китае и начните производство под private label уже сейчас."
  />
</Layout>