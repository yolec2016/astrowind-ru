---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Китайский завод кухонной техники | OEM/ODM поставщик оптом чайников и бытовой техники',
  description:
  'Китайский производитель мелкой кухонной техники. OEM и ODM производство электрических чайников, чайников для кофе, рисоварок, мультиварок, скороварок и электрических ланч-боксов для импортеров, дистрибьюторов, владельцев брендов и розничных сетей.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Получить предложение',
        href: 'https://www.yolec-electronics.com/contact/',
        target: '_blank',
        icon: 'tabler:message',
      },
      {
        text: 'Скачать каталог',
        href: 'https://www.yolec-electronics.com/products/',
        target: '_blank',
      },
    ]}
    image={{
      src: '~/assets/images/hero-image.png',
      alt: 'OEM/ODM производитель мелкой кухонной техники в Китае — электрические чайники, чайники для кофе, рисоварки, мультиварки, скороварки и электрические ланч-боксы'   }}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">OEM/ODM завод</span>
      <br />
      мелкой кухонной техники
      <br />
      в Китае
    </Fragment>

    <Fragment slot="subtitle">
      Китайский производитель мелкой кухонной техники, предоставляющий услуги OEM и ODM для импортеров, дистрибьюторов, владельцев брендов и розничных сетей.
      Мы производим электрические чайники, чайники для кофе, рисоварки, мультиварки, скороварки и электрические ланч-боксы, предлагая разработку продукции, изготовление пресс-форм, дизайн упаковки, контроль качества, сертификацию и экспортную поддержку.
      Помогаем B2B-партнёрам создавать конкурентоспособную продукцию под собственным брендом и успешно выводить её на рынок.
    </Fragment>


  </Hero>

  <!-- Note Widget ******************* -->

  <Note
    title="OEM/ODM производитель мелкой кухонной техники в Китае"
    description="Разработка продукции • Производство • Контроль качества • Сертификация • Экспорт"
  />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Почему выбирают наш завод"
    title="Почему международные B2B-покупатели выбирают YOLEC"
    subtitle="Мы сотрудничаем с импортерами, дистрибьюторами, оптовыми компаниями и владельцами брендов, которым требуется надежный OEM/ODM-производитель в Китае."
    items={[
      {
        title: 'OEM и ODM производство',
        description:
          'Производство мелкой кухонной техники по вашим требованиям: логотип, упаковка, цвет, технические характеристики и индивидуальная комплектация.',
        icon: 'tabler:settings',
      },
      {
        title: 'Собственное производство',
        description:
          'Современные производственные линии, участки литья пластика, обработки металла и профессиональная сборка для стабильного серийного производства.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Контроль качества',
        description:
          'Многоступенчатый контроль качества включает проверку сырья, производственного процесса, функциональное тестирование и финальную инспекцию перед отгрузкой.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Экспортная поддержка',
        description: 'Поддерживаем экспортные проекты, помогая подготовить необходимые документы и организовать международную доставку.',
        icon: 'tabler:world',
      },
      {
        title: 'Поддержка международной сертификации',
        description: 'Поддерживаем подготовку продукции к международной сертификации, включая CE, CB, LFGB, RoHS и другие требования различных рынков.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Быстрое коммерческое предложение',
        description: 'Наша команда оперативно подготовит коммерческое предложение, рассчитает стоимость проекта и ответит на технические вопросы.',
        icon: 'tabler:message-circle',
      },

      {
        title: 'Разработка продукции',
        description:
          'Помогаем разрабатывать новые модели, улучшать существующие изделия и адаптировать продукцию под требования различных рынков.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Изготовление пресс-форм',
        description:
          'Собственная разработка и изготовление пресс-форм позволяют быстрее запускать новые проекты и контролировать качество продукции.',
        icon: 'tabler:tool',
      },
      {
        title: 'Дизайн упаковки',
        description:
          'Разрабатываем упаковку, инструкции и оформление продукции в соответствии с требованиями вашего бренда и целевого рынка.',
        icon: 'tabler:package',
      },

    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="О заводе"
    title="Китайский производитель кухонной техники с OEM/ODM услугами"
    items={[
      {
        title: 'Завод основан в 2015 году',
        description: 'Более 10 лет опыта как OEM/ODM производитель кухонной техники в Китае.',
      },
      {
        title: 'Полный производственный цикл',
        description:
          'Металлообработка, литьё пластика, сборка и контроль качества — всё на одном заводе.',
      },
      {
        title: 'OEM и ODM проекты',
        description:
          'Поддерживаем производство продукции под брендом заказчика для импортеров, дистрибьюторов и международных B2B-компаний.',
      },
    ]}
    image={{
      src: '~/assets/images/Small-Home-Appliance-Manufacturer.png',
      alt: 'OEM ODM завод кухонной техники Китай',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        OEM/ODM завод кухонной техники в Китае для оптовых покупателей
      </h3>

      Мы производим электрические чайники, рисоварки, мультиварки, скороварки и ланч-боксы для импортеров, дистрибьюторов и владельцев брендов, которым нужен надежный поставщик кухонной техники из Китая.
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="Производственные возможности"
    title="Массовое производство кухонной техники оптом"
    items={[
      {
        title: '3 производственные линии завода',
        description: 'Стабильное производство электрических чайников, рисоварок и другой техники.',
      },
      {
        title: 'Внутренний QC контроль',
        description: 'Контроль качества на каждом этапе производства на фабрике.',
      },
      {
        title: 'OEM ODM гибкость',
        description: 'Поддержка индивидуального дизайна, упаковки и технических требований.',
      },
      {
        title: 'Быстрые образцы',
        description: 'Разработка и отправка образцов для проверки перед массовым заказом.',
      },
    ]}
    image={{
      src: '~/assets/images/factory.png',
      alt: 'Производство кухонной техники Китай завод',
    }}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="Ассортимент завода"
    title="Кухонная техника оптом от производителя в Китае"
    items={[
      {
        title: 'Электрические чайники оптом',
        description: 'Заводское производство стеклянных и нержавеющих моделей.',
      },
      {
        title: 'Рисоварки и мультиварки OEM',
        description: 'Модели для домашнего и коммерческого использования.',
      },
      {
        title: 'Скороварки',
        description: 'Энергоэффективные и безопасные решения от китайского завода.',
      },
      {
        title: 'Ланч-боксы электрические',
        description: 'Популярная продукция для розничных и онлайн рынков.',
      },
    ]}
    image={{
      src: '~/assets/images/gooseneck-coffee-kettle-new.png',
      alt: 'Ассортимент кухонной техники Китай завод',
    }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Как работает OEM/ODM завод в Китае"
    items={[
      {
        title: 'Запрос от клиента',
        description: 'Вы отправляете требования: продукт, объем, рынок, упаковка.',
        icon: 'tabler:message',
      },
      {
        title: 'Коммерческое предложение',
        description: 'Цена от завода, MOQ, сроки и условия поставки.',
        icon: 'tabler:file-text',
      },
      {
        title: 'OEM образцы',
        description: 'Производство образцов для подтверждения качества.',
        icon: 'tabler:flask',
      },
      {
        title: 'Массовое производство',
        description: 'Запуск фабрики и контроль качества.',
        icon: 'tabler:settings-cog',
      },
      {
        title: 'Отгрузка',
        description: 'Финальная проверка и экспорт кухонной техники.',
        icon: 'tabler:truck',
      },
    ]}
        image={{
      src: '~/assets/images/oem.png',
      alt: 'Ассортимент кухонной техники Китай завод',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Почему B2B покупатели выбирают наш завод"
    subtitle="Китайский OEM/ODM производитель кухонной техники для оптовых клиентов"
    tagline="Китайский производитель"
    items={[
      {
        title: 'OEM/ODM завод',
        description: 'Производство под брендом клиента для мировых рынков.',
        icon: 'flat-color-icons:factory',
      },
      {
        title: 'Стабильное качество',
        description: 'Контроль качества на каждом этапе производства.',
        icon: 'flat-color-icons:search',
      },
      {
        title: 'Экспортная фабрика',
        description: 'Опыт поставок в Европу, Ближний Восток и Азию.',
        icon: 'flat-color-icons:globe',
      },
      {
        title: 'Производственная мощность',
        description: '200 сотрудников и 3 линии производства.',
        icon: 'flat-color-icons:factory',
      },
      {
        title: 'Быстрая коммуникация',
        description: 'Ответ от завода в течение 24 часов.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Производство под брендом заказчика',
        description: 'Нанесение логотипа, индивидуальная упаковка и OEM/ODM производство в соответствии с требованиями клиента.',
        icon: 'flat-color-icons:approval',
      },
    ]}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Часто задаваемые вопросы"
    subtitle="Ответы на вопросы импортеров, дистрибьюторов и владельцев брендов о сотрудничестве с нашим OEM/ODM заводом в Китае"
    items={[
      {
        title: 'Вы производитель или торговая компания?',
        description:
          'YOLEC — производитель мелкой кухонной техники в Китае. Мы располагаем собственными производственными линиями и предоставляем услуги OEM и ODM без посредников.',
      },
      {
        title: 'Какие услуги OEM и ODM вы предоставляете?',
        description:
          'Мы предлагаем разработку продукции, изготовление пресс-форм, индивидуальный дизайн, брендирование, производство, контроль качества, поддержку сертификации и экспортные услуги.',
      },
      {
        title: 'Можно ли производить продукцию под нашим брендом?',
        description:
          'Да. Мы производим продукцию под брендом заказчика, включая нанесение логотипа, индивидуальную упаковку, инструкции и другие элементы фирменного оформления.',
      },
      {
        title: 'Какой минимальный объем заказа (MOQ)?',
        description:
          'Минимальный объем заказа зависит от модели продукции и уровня индивидуальной доработки. Наш отдел продаж предложит оптимальное решение для вашего проекта.',
      },
      {
        title: 'Какие сертификаты доступны?',
        description:
          'Мы поддерживаем подготовку продукции к международной сертификации, включая CE, CB, LFGB, RoHS и другие требования в зависимости от рынка назначения.',
      },
      {
        title: 'Сколько занимает производство заказа?',
        description:
          'В большинстве случаев производство занимает от 30 до 45 дней после утверждения образцов и подтверждения заказа. Срок зависит от модели и объема заказа.',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Год основания', amount: '2015' },
      { title: 'Сотрудники', amount: '200+' },
      { title: 'Производственные линии', amount: '3' },
      { title: 'OEM / ODM проектов', amount: '1000+' },
    ]}
  />

    <!-- WhatsApp Proof Section -->
<div class="mt-16 flex justify-center">
  <div class="w-full max-w-4xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-lg p-6 md:p-10">

    <!-- Title -->
    <h3 class="text-center text-2xl md:text-3xl font-bold text-slate-900 dark:text-white">
      Реальные переписки с покупателями в WhatsApp
    </h3>

    <p class="text-center text-slate-500 dark:text-slate-400 mt-2">
      Запросы от импортеров, дистрибьюторов и владельцев брендов со всего мира
    </p>

    <!-- Trust badges -->
    <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm">
      <span class="px-3 py-1 rounded-full bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300">
        ✔ Ответ в течение 24 часов
      </span>

      <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
        ✔ OEM / ODM производство напрямую от завода
      </span>

      <span class="px-3 py-1 rounded-full bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300">
        ✔ Поддержка сертификации CE • CB • LFGB
      </span>
    </div>

    <!-- CTA -->
    <div class="mt-6 flex justify-center">
      <a
        href="https://wa.me/8613922332584"
        target="_blank"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold transition"
      >
        Связаться с заводом через WhatsApp
      </a>
    </div>

  </div>
</div>

  <div class="flex justify-center items-center mt-10">
  <img
    src= '/images/whatsapp.png',
    alt="Contacto directo con fabricantes OEM de electrodomésticos de cocina en China a través de WhatsApp y WeChat"
    class="mx-auto max-w-full h-auto w-[180px] md:w-[220px] rounded-lg shadow-md"
    loading="lazy"
  />
  </div>


</Layout>