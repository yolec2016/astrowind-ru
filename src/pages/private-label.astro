---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title:
    'Private Label производитель кухонной техники в Китае | OEM производство под собственной торговой маркой',

  description:
    'YOLEC — китайский производитель кухонной техники, предоставляющий услуги Private Label, OEM и ODM. Производство электрических чайников, чайников для кофе, рисоварок, мультиварок, скороварок и электрических ланч-боксов для импортеров, дистрибьюторов и владельцев брендов.',
};
---

<Layout metadata={metadata}>

  <!-- Hero -->

  <HeroText
    tagline="Private Label производитель кухонной техники в Китае"
    title="Private Label производство кухонной техники под вашим брендом"
    subtitle="YOLEC — китайский производитель мелкой кухонной техники, предлагающий услуги Private Label, OEM и ODM для международных брендов, импортеров, дистрибьюторов, розничных сетей и продавцов электронной коммерции. Мы сопровождаем проекты от разработки продукции и брендирования до массового производства и экспортной поддержки."
  />

  <!-- Pricing -->

  <Prices
    title="Варианты сотрудничества Private Label"
    subtitle="Стоимость проекта рассчитывается индивидуально в зависимости от модели продукции, уровня кастомизации, объема заказа и требований к упаковке."

    prices={[
      {
        title: 'White Label',
        subtitle: 'Готовая продукция с вашим логотипом',
        price: 0,
        period: 'Индивидуальный расчет',

        items: [
          { description: 'Нанесение логотипа' },
          { description: 'Стандартная упаковка' },
          { description: 'Готовые модели' },
          { description: 'Минимальный MOQ' },
        ],

        callToAction: {
          text: 'Получить предложение',
          href: 'https://www.yolec-electronics.com/contact/',
          target: '_blank',
        },
      },

      {
        title: 'OEM Manufacturing',
        subtitle: 'Производство под требования вашего бренда',
        price: 0,
        period: 'Индивидуальный расчет',

        items: [
          { description: 'Индивидуальный логотип' },
          { description: 'Разработка упаковки' },
          { description: 'Выбор цвета и материалов' },
          { description: 'Разработка образцов' },
          { description: 'Полный контроль качества' },
        ],

        hasRibbon: true,
        ribbonTitle: 'Самый популярный',

        callToAction: {
          text: 'Запросить OEM предложение',
          href: 'https://www.yolec-electronics.com/contact/',
          target: '_blank',
        },
      },

      {
        title: 'ODM + Private Label',
        subtitle: 'Полностью новый продукт под вашим брендом',
        price: 0,
        period: 'Индивидуальный расчет',

        items: [
          { description: 'Разработка новой модели' },
          { description: 'Изготовление пресс-форм' },
          { description: 'Инженерная поддержка' },
          { description: 'Эксклюзивный дизайн' },
          { description: 'Серийное производство' },
        ],

        callToAction: {
          text: 'Начать ODM проект',
          href: 'https://www.yolec-electronics.com/contact/',
          target: '_blank',
        },
      },
    ]}
  />
  <!-- Features3 Widget ************** -->

  <Features3
    title="Почему международные покупатели выбирают наше Private Label производство"
    subtitle="Преимущества сотрудничества с китайским OEM/ODM производителем кухонной техники"
    columns={2}
    items={[
      {
        title: 'Полное Private Label производство',
        description:
          'Разработка продукции под вашим брендом, включая логотип, упаковку, инструкции и фирменный стиль.',
      },
      {
        title: 'Прямой китайский производитель',
        description:
          'Вы работаете напрямую с заводом без посредников, что позволяет снизить закупочную стоимость.',
      },
      {
        title: 'OEM и ODM решения',
        description:
          'Предлагаем как готовые модели для быстрого запуска бренда, так и полностью индивидуальную разработку продукции.',
      },
      {
        title: 'Строгий контроль качества',
        description:
          'Контроль качества осуществляется на каждом этапе производства перед экспортом.',
      },
      {
        title: 'Международная сертификация',
        description:
          'Поддерживаем подготовку продукции к требованиям CE, CB, LFGB, RoHS и других международных стандартов.',
      },
      {
        title: 'Экспорт по всему миру',
        description:
          'Регулярные поставки для импортеров, дистрибьюторов и владельцев брендов в Европе, на Ближнем Востоке, в Южной Америке и других регионах.',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Как проходит Private Label проект"
    tagline="От идеи до массового производства"
    isReversed={true}
    items={[
      {
        title: 'Обсуждение требований проекта',
      },
      {
        title: 'Подбор модели или разработка нового продукта',
      },
      {
        title: 'Подготовка логотипа и дизайна упаковки',
      },
      {
        title: 'Изготовление и утверждение образцов',
      },
      {
        title: 'Массовое производство',
      },
      {
        title: 'Контроль качества и инспекция',
      },
      {
        title: 'Экспорт и международная доставка',
      },
    ]}
    image={{
      src: '~/assets/images/factory5.png',
      alt: 'Private label kitchen appliance manufacturing process in China',
    }}
  />
    <!-- FAQs Widget ******************* -->

  <FAQs
    title="Часто задаваемые вопросы о Private Label производстве"
    subtitle="Ответы на наиболее популярные вопросы импортеров, дистрибьюторов и владельцев брендов."
    columns={1}
    items={[
      {
        title: 'Какой минимальный объем заказа (MOQ)?',
        description:
          'Минимальный объем заказа обычно начинается от 1000 единиц и зависит от модели продукции, уровня кастомизации и требований проекта.',
      },
      {
        title: 'Можно ли использовать собственный логотип?',
        description:
          'Да. Мы предлагаем нанесение логотипа, индивидуальную упаковку, инструкции пользователя и полное брендирование продукции.',
      },
      {
        title: 'Предоставляете ли вы услуги OEM и ODM?',
        description:
          'Да. Мы предлагаем как OEM производство на базе существующих моделей, так и ODM разработку новых продуктов под требования вашего рынка.',
      },
      {
        title: 'Какие виды кухонной техники вы производите?',
        description:
          'Мы производим электрические чайники, чайники для кофе, рисоварки, мультиварки, скороварки, электрические ланч-боксы и другую мелкую кухонную технику.',
      },
      {
        title: 'Какие сертификаты поддерживаются?',
        description:
          'Мы поддерживаем подготовку продукции к международной сертификации, включая CE, CB, RoHS, LFGB и другие требования различных рынков.',
      },
      {
        title: 'Сколько времени занимает производство?',
        description:
          'Как правило, массовое производство занимает от 30 до 45 дней после подтверждения образцов и оформления заказа.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Начните выпуск собственной линейки кухонной техники"
    subtitle="Свяжитесь напрямую с китайским OEM/ODM производителем и получите коммерческое предложение, образцы продукции и профессиональную поддержку вашего Private Label проекта."
    actions={[
      {
        variant: 'primary',
        text: 'Получить предложение от производителя',
        href: 'https://www.yolec-electronics.com/contact/',
        target: '_blank',
      },
    ]}
  />

</Layout>  