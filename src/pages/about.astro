      {
        title: 'Оперативная коммуникация',
        description:
          'Предоставляем коммерческие предложения и техническую поддержку в кратчайшие сроки.',
        icon: 'tabler:message-circle',
      },
    ]}
  />

  <!-- WHY THIS FACTORY ===================== -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Прямой завод (не посредник)',
        description:
          'OEM/ODM производитель кухонной техники в Китае без торговых компаний.',
        icon: 'tabler:template',
      },
      {
        title: 'OEM/ODM производство под бренд',
