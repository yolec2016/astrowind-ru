---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title:
    'О компании YOLEC | OEM/ODM производитель мелкой кухонной техники в Китае',

  description:
    'YOLEC — китайский производитель мелкой кухонной техники. OEM и ODM производство электрических чайников, чайников для кофе, рисоварок, мультиварок, скороварок и электрических ланч-боксов для импортеров, дистрибьюторов и владельцев брендов.',
};
---

<Layout metadata={metadata}>

  <!-- HERO ===================== -->

  <Hero
    tagline="Китайский OEM/ODM завод кухонной бытовой техники"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=2070&q=80',
      alt: 'OEM/ODM производитель мелкой кухонной техники в Китае',
    }}
  >
    <Fragment slot="title">
       О компании YOLEC <br />
      <span class="text-accent dark:text-white">
        OEM/ODM производитель мелкой кухонной техники в Китае
      </span>
    </Fragment>

    <Fragment slot="subtitle">
      YOLEC — китайский производитель мелкой кухонной техники, специализирующийся на OEM и ODM производстве для международных импортеров, дистрибьюторов, владельцев брендов и розничных сетей.      Производим и поставляем кухонную бытовую технику для B2B клиентов по всему миру.
      Специализация: электрические чайники, стеклянные чайники, gooseneck кофейные чайники, рисоварки, мультиварки,
      IH cooker, скороварки, ланч-боксы и другая мелкая кухонная техника.
      Работаем только с оптовыми B2B заказами и OEM/ODM проектами.
    </Fragment>
  </Hero>

  <!-- STRONG PROOF STATS ===================== -->

  <Stats
    title="Факты о заводе (OEM/ODM производитель из Китая)"
    stats={[
      { title: 'Производственная база', amount: '20000㎡' },
      { title: 'Сотрудники', amount: '200+' },
      { title: 'Производственные линии', amount: '3' },
      { title: 'OEM/ODM проектов', amount: '1000+' },
    ]}
  />

    <Content
    tagline="Наша миссия"
    title="Помогаем мировым брендам создавать качественную кухонную технику"
    image={{
      src: '~/assets/images/factory-mission.png',
      alt: 'OEM ODM производитель мелкой кухонной техники в Китае',
    }}
    items={[
      {
        title: 'Ориентация на B2B',
        description:
          'Работаем исключительно с импортерами, дистрибьюторами, владельцами брендов и розничными сетями.',
      },
      {
        title: 'Долгосрочное сотрудничество',
        description:
          'Стремимся выстраивать стабильные партнерские отношения и помогать клиентам развивать собственные бренды.',
      },
      {
        title: 'Комплексные OEM/ODM решения',
        description:
          'От разработки продукции до массового производства, контроля качества и экспортной поддержки.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Наша миссия
      </h3>

      <p class="mt-4">
        Миссия YOLEC — помогать импортерам, дистрибьюторам и владельцам брендов создавать конкурентоспособную мелкую кухонную технику с помощью профессионального OEM и ODM производства в Китае. Мы стремимся обеспечить стабильное качество продукции, эффективное производство и долгосрочное сотрудничество с международными партнерами.
      </p>
    </Fragment>
  </Content>

  <!-- CORE PRODUCTS ===================== -->

  <!-- ABOUT COMPANY ===================== -->

  <Content
    tagline="О компании YOLEC"
    title="Китайский производитель мелкой кухонной техники"
    items={[
      {
        title: 'OEM и ODM производство',
        description:
          'Предоставляем комплексные OEM и ODM услуги для международных B2B клиентов.',
