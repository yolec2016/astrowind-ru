---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title:
    'OEM/ODM производство мелкой кухонной техники в Китае | Производитель под брендом заказчика',
  description:
    'OEM и ODM производство мелкой кухонной техники в Китае. Производство электрических чайников, чайников для кофе, рисоварок, мультиварок, скороварок и электрических ланч-боксов для импортеров, дистрибьюторов и владельцев брендов.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="OEM / ODM производство в Китае"
    title="OEM/ODM производитель мелкой кухонной техники в Китае"
    subtitle="Мы предоставляем услуги OEM и ODM по производству электрических чайников, чайников для кофе, рисоварок, мультиварок, скороварок и электрических ланч-боксов для импортеров, дистрибьюторов, владельцев брендов и розничных сетей. Предлагаем разработку продукции, изготовление пресс-форм, брендирование, производство, контроль качества и экспортную поддержку."
    actions={[
      { variant: 'primary', text: 'Получить цену OEM от завода', href: 'https://www.yolec-electronics.com/contact/', target: '_blank', }
    ]}
    image={{
      src: '~/assets/images/factory2.png',
      alt: 'OEM и ODM производство электрических чайников, рисоварок и другой мелкой кухонной техники на заводе в Китае',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Что включает наше OEM/ODM производство"
    subtitle="Полный комплекс услуг по разработке и производству мелкой кухонной техники под требования вашего бренда."
    columns={3}
    items={[
      {
        title: 'OEM производство под брендом заказчика',
        description:
          'Производство кухонной техники под вашим брендом: логотип, упаковка, инструкции, цвет и технические характеристики продукции.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Разработка новых моделей (ODM)',
        description:
          'Разработка новых моделей кухонной техники под ваш рынок и требования.',
        icon: 'tabler:tools',
      },
      {
        title: 'Индивидуальный дизайн упаковки',
        description:
          'Разрабатываем индивидуальный дизайн упаковки, инструкции и фирменного оформления в соответствии с требованиями вашего бренда.',
        icon: 'tabler:package',
      },
      {
        title: 'Контроль качества (QC)',
        description:
          'Проверка сырья, контроль производства, тестирование и финальная инспекция.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Экспортная поддержка',
        description:
          'Поддерживаем международные поставки и подготовку экспортной документации.',
        icon: 'tabler:world',
      },
      {
        title: 'Разработка и производство образцов',
        description:
          'Разработка и производство образцов для проверки перед массовым заказом.',
        icon: 'tabler:clock',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Собственный завод в Китае',
        description:
          'Полный производственный цикл: металлообработка, литьё пластика, сборка и тестирование.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Стабильное массовое производство',
        description:
          '200 сотрудников и 3 производственные линии для стабильных оптовых поставок.',
        icon: 'tabler:stack',
      },
      {
        title: 'Гибкость OEM / ODM',
        description:
          'Поддержка малых и крупных заказов для разных рынков и брендов.',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Инженерная поддержка',
        description:
          'Поддержка разработки продукта, улучшений и технических решений.',
        icon: 'tabler:cpu',
      },
    ]}
    image={{
      src: '~/assets/images/factory3.png',
      alt: 'Производственная линия завода по производству мелкой кухонной техники в Китае',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        OEM/ODM завод кухонной техники в Китае для оптовых покупателей
      </h3>
      <p class="mt-4">
      Мы сопровождаем OEM и ODM проекты от разработки продукции и изготовления пресс-форм до массового производства, контроля качества и подготовки продукции к экспорту. Такой комплексный подход помогает импортерам и владельцам брендов быстрее выводить новые продукты на рынок.
      </p>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Снижение себестоимости',
        description:
          'Прямые заводские цены без посредников для импортеров и дистрибьюторов.',
        icon: 'tabler:coin',
      },
      {
        title: 'Быстрый запуск продукта',
        description:
          'Быстрая разработка и запуск OEM/ODM проектов.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Производство под брендом заказчика',
        description:
          'Разработка упаковки, нанесение логотипа и оформление продукции в соответствии с фирменным стилем клиента.',
        icon: 'tabler:brush',
      },
      {
        title: 'Готовность к экспорту',
        description:
          'Поддержка подготовки продукции к международной сертификации, включая CE, CB, RoHS, LFGB и другие требования различных рынков.',
        icon: 'tabler:checklist',
      },
    ]}
    image={{
      src: '~/assets/images/factory4.png',
      alt: 'Преимущества OEM и ODM производства мелкой кухонной техники на заводе в Китае',
    }}
  />

   <!-- FAQs Widget ******************* -->

  <FAQs
    title="Часто задаваемые вопросы об OEM/ODM производстве"
    subtitle="Ответы на вопросы импортеров, дистрибьюторов и владельцев брендов о сотрудничестве с нашим заводом в Китае."
    items={[
      {
        title: 'Вы производитель или торговая компания?',
        description:
          'Мы являемся производителем мелкой кухонной техники в Китае и предоставляем услуги OEM и ODM без посредников.',
      },
      {
        title: 'Какие OEM/ODM услуги вы предлагаете?',
        description:
          'Мы предоставляем разработку продукции, изготовление пресс-форм, нанесение логотипа, дизайн упаковки, производство, контроль качества и экспортную поддержку.',
      },
      {
        title: 'Можно ли производить продукцию под нашим брендом?',
        description:
          'Да. Мы поддерживаем производство под брендом заказчика, включая логотип, упаковку, инструкции и другие элементы фирменного оформления.',
      },
      {
        title: 'Какой минимальный объем заказа (MOQ)?',
        description:
          'Минимальный объем заказа зависит от модели продукции и требований к индивидуальной доработке. Мы предложим оптимальное решение после обсуждения проекта.',
      },
      {
        title: 'Какие сертификаты поддерживаются?',
        description:
          'Мы поддерживаем подготовку продукции к международной сертификации, включая CE, CB, LFGB, RoHS и другие требования различных рынков.',
      },
      {
        title: 'Сколько времени занимает производство?',
        description:
          'Обычно производство занимает от 30 до 45 дней после утверждения образцов и подтверждения заказа. Конкретные сроки зависят от модели и объема заказа.',
      },
    ]}
  /> 

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Отзывы B2B клиентов"
    testimonials={[
      {
        testimonial:
          'Мы заказали OEM электрические чайники под private label. Качество стабильное и поставки вовремя.',
        name: 'Европейский импортер',
        job: 'B2B закупки',
      },
      {
        testimonial:
          'ODM-проект был реализован быстро, а новая модель успешно вышла на целевой рынок.',
        name: 'Международный дистрибьютор',
        job: 'Wholesale Distributor',
      },
      {
        testimonial:
          'Надежный производитель с высокой производственной мощностью и стабильным качеством продукции.',
        name: 'Владелец бренда',
        job: 'Private Label Brand',
      },
    ]}
    callToAction={{
      target: '_blank',
      text: 'Запросить больше кейсов',
      href: 'https://www.yolec-electronics.com/about/',
      target: '_blank',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Получить OEM/ODM прайс от завода',
        href: 'https://www.yolec-electronics.com/contact/',
        target: '_blank',
      },
    ]}
    title="Начните OEM/ODM проект с китайским производителем"
    subtitle="Получите коммерческое предложение напрямую от китайского OEM/ODM завода за 24 часа."
  />

</Layout>